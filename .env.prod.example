# ── Session & Auth ─────────────────────────────────────────────────
# Random string — generate with: python -c "import secrets; print(secrets.token_hex(32))"
SESSION_SECRET=change-me

# Bcrypt hash of your login password — generate with: python manage_orgs.py hash-password
APP_PASSWORD_HASH=

# ── Org credential encryption ──────────────────────────────────────
# Fernet key — generate with: python manage_orgs.py generate-key
FC_ENCRYPTION_KEY=

# ── App settings ───────────────────────────────────────────────────
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=false

# Sub-path prefix if served at a path (e.g. /gcanalyzer). Leave empty for subdomain.
APP_ROOT_PATH=
